#!/usr/bin/env bash
set -euo pipefail

# Portable script-dir resolution (no GNU readlink — works on macOS too).
resolve_script_dir() {
    local source="${BASH_SOURCE[0]}"
    while [[ -L "$source" ]]; do
        local dir
        dir="$(cd -P "$(dirname "$source")" && pwd)"
        source="$(readlink "$source")"
        if [[ "$source" != /* ]]; then source="$dir/$source"; fi
    done
    cd -P "$(dirname "$source")" && pwd
}
SCRIPT_DIR="$(resolve_script_dir)"

# Config-file resolution. Historically the config lived next to the script,
# which is ideal for a clone+symlink install. But when the script is installed
# into a read-only prefix (e.g. the Nix store), that directory can't be written,
# so we fall back to the XDG location. Resolution order:
#   1. $LOCAL_REPO_CONF, if set — explicit override (used by the Nix package).
#   2. an existing conf next to the script — keeps legacy / macOS installs working.
#   3. an existing conf under $XDG_CONFIG_HOME (default ~/.config).
#   4. neither exists yet: write next to the script if that dir is writable
#      (legacy behaviour), otherwise under $XDG_CONFIG_HOME.
resolve_config_file() {
    if [[ -n "${LOCAL_REPO_CONF:-}" ]]; then
        printf '%s\n' "$LOCAL_REPO_CONF"
        return
    fi
    local legacy="${SCRIPT_DIR}/local-repo.conf"
    local xdg="${XDG_CONFIG_HOME:-$HOME/.config}/local-repo/local-repo.conf"
    if [[ -f "$legacy" ]]; then
        printf '%s\n' "$legacy"
    elif [[ -f "$xdg" ]]; then
        printf '%s\n' "$xdg"
    elif [[ -w "$SCRIPT_DIR" ]]; then
        printf '%s\n' "$legacy"
    else
        printf '%s\n' "$xdg"
    fi
}
CONFIG_FILE="$(resolve_config_file)"

NAS_USER=""
NAS_HOST=""
NAS_PORT=""
NAS_REPOS_DIR="repos"

SSH_BASE_OPTS=()

load_config() {
    if [[ -f "$CONFIG_FILE" ]]; then
        # shellcheck disable=SC1090
        source "$CONFIG_FILE"
    fi
    SSH_BASE_OPTS=()
    if [[ -n "$NAS_PORT" ]]; then
        SSH_BASE_OPTS=(-p "$NAS_PORT")
    fi
    # Also catch a hand-edited config, not just one written by 'config set'.
    validate_repos_dir "$NAS_REPOS_DIR"
}

write_config() {
    mkdir -p "$(dirname "$CONFIG_FILE")"
    cat > "$CONFIG_FILE" <<EOF
# local-repo configuration — managed by 'local-repo config set <key> <value>'

NAS_USER="${NAS_USER}"
NAS_HOST="${NAS_HOST}"
NAS_PORT="${NAS_PORT}"
NAS_REPOS_DIR="${NAS_REPOS_DIR}"
EOF
    chmod 600 "$CONFIG_FILE"
}

require_remote_config() {
    if [[ -z "$NAS_USER" || -z "$NAS_HOST" ]]; then
        cat >&2 <<EOF
error: SSH connection is not configured.

Run:
  local-repo config set user <username>
  local-repo config set host <hostname-or-ip>

See 'local-repo status' or 'local-repo config' for current settings.
EOF
        exit 2
    fi
}

remote_url() {
    local name="$1"
    local remote_path="${NAS_REPOS_DIR}/${name}.git"
    if [[ -n "$NAS_PORT" ]]; then
        echo "ssh://${NAS_USER}@${NAS_HOST}:${NAS_PORT}/~/${remote_path}"
    else
        echo "${NAS_USER}@${NAS_HOST}:~/${remote_path}"
    fi
}

usage() {
    cat <<EOF
Usage:

Main workflows:
  local-repo init                  start a new project here: prompts for a name,
                                   creates the bare repo on the server, runs
                                   'git init' in the current directory, and
                                   sets origin to the server URL
  local-repo set-backup [--mirror] back up the repo in the current directory:
                                   creates <repo-name>-backup.git on the server,
                                   adds a 'backup' remote here, and pushes all
                                   branches/tags. with --mirror, also wires the
                                   backup URL into origin's push URLs so that
                                   'git push' mirrors to it automatically.
                                   re-run to refresh.

Other commands:
  local-repo create <name>         create a bare repo on the remote (no local init)
  local-repo list                  list bare repos (alias: ls)
  local-repo delete <name> [-f]    delete a repo (alias: rm; -f skips confirm)
  local-repo url <name>            print the git remote URL for <name>
  local-repo status                show SSH connection status and current config
  local-repo config [...]          show or change SSH connection settings

Config file: ${CONFIG_FILE}
EOF
}

validate_name() {
    if [[ ! "$1" =~ ^[A-Za-z0-9._-]+$ ]]; then
        echo "error: repo name must contain only letters, digits, '.', '_', '-'" >&2
        exit 2
    fi
}

# The config file is sourced as bash and write_config emits values inside double
# quotes, so these characters would corrupt it on the next load.
validate_conf_value() {
    case "$2" in
        *[\"\$\`\\]*)
            printf 'error: %s must not contain a quote, $, backtick or backslash\n' "$1" >&2
            exit 2
            ;;
    esac
}

# NAS_REPOS_DIR is interpolated into remote command strings as '${NAS_REPOS_DIR}',
# so an apostrophe would close that quote and run as remote shell code.
validate_repos_dir() {
    validate_conf_value repos-dir "$1"
    case "$1" in
        *\'*)
            echo "error: repos-dir must not contain an apostrophe" >&2
            exit 2
            ;;
        "")
            echo "error: repos-dir must not be empty" >&2
            exit 2
            ;;
    esac
}

cmd_init() {
    if [[ $# -ne 0 ]]; then
        echo "usage: local-repo init" >&2
        exit 2
    fi

    require_remote_config

    if git rev-parse --git-dir >/dev/null 2>&1; then
        echo "error: already inside a git repo" >&2
        echo "       use 'local-repo set-backup' to back up an existing repo," >&2
        echo "       or 'local-repo create <name>' to make just the remote bare repo." >&2
        exit 1
    fi

    local default_name name
    default_name="$(basename "$PWD")"
    printf "repo name [%s]: " "$default_name"
    read -r name
    if [[ -z "$name" ]]; then
        name="$default_name"
    fi
    name="${name%.git}"
    validate_name "$name"

    local remote_path="${NAS_REPOS_DIR}/${name}.git"
    local url
    url="$(remote_url "$name")"

    ssh ${SSH_BASE_OPTS[@]+"${SSH_BASE_OPTS[@]}"} "${NAS_USER}@${NAS_HOST}" "
        set -e
        cd ~
        if [ -e '${remote_path}' ]; then
            echo \"error: ~/${remote_path} already exists on \$(hostname)\" >&2
            exit 1
        fi
        mkdir -p '${NAS_REPOS_DIR}'
        git init --bare '${remote_path}' >/dev/null
        echo \"created ~/${remote_path} on \$(hostname)\"
    "

    git init
    git remote add origin "$url"

    echo
    echo "origin set to: ${url}"
    echo
    echo "next steps:"
    echo "  git add ."
    echo "  git commit -m 'initial commit'"
    echo "  git push -u origin main"
}

configure_mirror_push() {
    local backup_url="$1"

    if ! git remote get-url origin >/dev/null 2>&1; then
        echo
        echo "error: --mirror needs an existing 'origin' remote to mirror from." >&2
        echo "       it's intended for repos whose origin is somewhere else" >&2
        echo "       (e.g. GitHub) that you also want backed up to the server." >&2
        exit 1
    fi

    local origin_fetch
    origin_fetch="$(git remote get-url origin)"

    # `git config --get-all` exits 1 when the key is unset; `|| true` keeps
    # set -e happy and leaves the var empty in that case.
    local existing_pushurls
    existing_pushurls="$(git config --get-all remote.origin.pushurl 2>/dev/null || true)"

    if [[ -z "$existing_pushurls" ]]; then
        # No explicit pushurls yet: a `git push origin` currently goes to the
        # fetch URL implicitly. Adding any explicit pushurl turns that off, so
        # preserve the existing destination by adding the fetch URL first.
        git remote set-url --add --push origin "$origin_fetch"
        git remote set-url --add --push origin "$backup_url"
        echo
        echo "mirror configured: 'git push origin' now pushes to both:"
        echo "  ${origin_fetch}"
        echo "  ${backup_url}"
        return
    fi

    if grep -Fxq -- "$backup_url" <<<"$existing_pushurls"; then
        echo
        echo "mirror already configured (origin push URLs already include backup)"
        return
    fi

    git remote set-url --add --push origin "$backup_url"
    echo
    echo "mirror configured: appended backup to origin's push URLs:"
    while IFS= read -r u; do echo "  ${u}"; done <<<"$existing_pushurls"
    echo "  ${backup_url}"
}

cmd_set_backup() {
    local mirror=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --mirror) mirror=1; shift ;;
            -*) echo "error: unknown flag '$1'" >&2; exit 2 ;;
            *)  echo "error: unexpected argument '$1'" >&2; exit 2 ;;
        esac
    done

    require_remote_config

    local toplevel
    if ! toplevel="$(git rev-parse --show-toplevel 2>/dev/null)"; then
        echo "error: not inside a git repo" >&2
        echo "       run this from inside the repo you want to back up." >&2
        exit 1
    fi

    local name
    name="$(basename "$toplevel")"
    validate_name "$name"

    local backup_name="${name}-backup"
    local remote_path="${NAS_REPOS_DIR}/${backup_name}.git"
    local url
    url="$(remote_url "$backup_name")"

    ssh ${SSH_BASE_OPTS[@]+"${SSH_BASE_OPTS[@]}"} "${NAS_USER}@${NAS_HOST}" "
        set -e
        cd ~
        mkdir -p '${NAS_REPOS_DIR}'
        if [ -d '${remote_path}' ]; then
            echo \"reusing existing ~/${remote_path} on \$(hostname)\"
        else
            git init --bare '${remote_path}' >/dev/null
            echo \"created ~/${remote_path} on \$(hostname)\"
        fi
    "

    if git remote get-url backup >/dev/null 2>&1; then
        local existing
        existing="$(git remote get-url backup)"
        if [[ "$existing" != "$url" ]]; then
            echo "error: local remote 'backup' already exists with a different URL:" >&2
            echo "         ${existing}" >&2
            echo "       remove it first with: git remote remove backup" >&2
            exit 1
        fi
        echo "local remote 'backup' already points at ${url}"
    else
        git remote add backup "$url"
        echo "added local remote 'backup' → ${url}"
    fi

    echo
    echo "pushing all branches and tags..."
    git push backup --all
    git push backup --tags

    if [[ $mirror -eq 1 ]]; then
        configure_mirror_push "$url"
    fi

    echo
    if [[ $mirror -eq 1 ]]; then
        echo "to refresh manually (the mirror does this automatically on 'git push'):"
    else
        echo "to refresh the backup later:"
    fi
    echo "  git push backup --all && git push backup --tags"
}

cmd_create() {
    if [[ $# -ne 1 ]]; then
        usage >&2
        exit 2
    fi

    require_remote_config

    local name="${1%.git}"
    validate_name "$name"

    local remote_path="${NAS_REPOS_DIR}/${name}.git"
    local url
    url="$(remote_url "$name")"

    ssh ${SSH_BASE_OPTS[@]+"${SSH_BASE_OPTS[@]}"} "${NAS_USER}@${NAS_HOST}" "
        set -e
        cd ~
        if [ -e '${remote_path}' ]; then
            echo \"error: ~/${remote_path} already exists on \$(hostname)\" >&2
            exit 1
        fi
        mkdir -p '${NAS_REPOS_DIR}'
        git init --bare '${remote_path}' >/dev/null
        echo \"created ~/${remote_path} on \$(hostname)\"
    "

    echo
    echo "remote URL: ${url}"
    echo
    echo "add to current repo with:"
    echo "  git remote add origin ${url}"
}

cmd_list() {
    if [[ $# -ne 0 ]]; then
        usage >&2
        exit 2
    fi

    require_remote_config

    ssh ${SSH_BASE_OPTS[@]+"${SSH_BASE_OPTS[@]}"} "${NAS_USER}@${NAS_HOST}" "
        set -e
        if [ ! -d ~/'${NAS_REPOS_DIR}' ]; then
            echo 'no ~/${NAS_REPOS_DIR} directory on \$(hostname)' >&2
            exit 0
        fi
        cd ~/'${NAS_REPOS_DIR}'
        shopt -s nullglob
        found=0
        for d in *.git; do
            [ -d \"\$d\" ] || continue
            found=1
            size=\$(du -sh \"\$d\" 2>/dev/null | cut -f1)
            printf '%-8s  %s\n' \"\$size\" \"\${d%.git}\"
        done
        if [ \$found -eq 0 ]; then
            echo '(no repos)'
        fi
    "
}

cmd_delete() {
    local force=0
    local name=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -f|--force) force=1; shift ;;
            -*) echo "error: unknown flag '$1'" >&2; exit 2 ;;
            *)
                if [[ -n "$name" ]]; then
                    echo "error: too many arguments" >&2
                    exit 2
                fi
                name="$1"; shift
                ;;
        esac
    done

    if [[ -z "$name" ]]; then
        usage >&2
        exit 2
    fi

    require_remote_config

    name="${name%.git}"
    validate_name "$name"

    local remote_path="${NAS_REPOS_DIR}/${name}.git"

    if [[ $force -ne 1 ]]; then
        printf "delete ~/%s on %s@%s? [y/N] " "$remote_path" "$NAS_USER" "$NAS_HOST"
        read -r answer
        case "$answer" in
            y|Y|yes|YES) ;;
            *) echo "aborted"; exit 1 ;;
        esac
    fi

    ssh ${SSH_BASE_OPTS[@]+"${SSH_BASE_OPTS[@]}"} "${NAS_USER}@${NAS_HOST}" "
        set -e
        cd ~
        if [ ! -d '${remote_path}' ]; then
            echo \"error: ~/${remote_path} does not exist on \$(hostname)\" >&2
            exit 1
        fi
        rm -rf '${remote_path}'
        echo \"deleted ~/${remote_path} on \$(hostname)\"
    "
}

cmd_url() {
    if [[ $# -ne 1 ]]; then
        echo "usage: local-repo url <name>" >&2
        exit 2
    fi

    require_remote_config

    local name="${1%.git}"
    validate_name "$name"
    remote_url "$name"
}

cmd_status() {
    if [[ $# -ne 0 ]]; then
        echo "usage: local-repo status" >&2
        exit 2
    fi

    echo "config file: ${CONFIG_FILE}"
    if [[ ! -f "$CONFIG_FILE" ]]; then
        echo "             (not present — run 'local-repo config set ...' to create)"
    fi
    echo
    echo "  user      = ${NAS_USER:-(unset)}"
    echo "  host      = ${NAS_HOST:-(unset)}"
    echo "  port      = ${NAS_PORT:-(default, 22)}"
    echo "  repos-dir = ~/${NAS_REPOS_DIR}"
    echo

    if [[ -z "$NAS_USER" || -z "$NAS_HOST" ]]; then
        echo "connection: not configured"
        exit 1
    fi

    local remote="${NAS_USER}@${NAS_HOST}"
    if [[ -n "$NAS_PORT" ]]; then
        printf 'connection: testing %s on port %s ... ' "$remote" "$NAS_PORT"
    else
        printf 'connection: testing %s ... ' "$remote"
    fi

    if ssh ${SSH_BASE_OPTS[@]+"${SSH_BASE_OPTS[@]}"} -o BatchMode=yes -o ConnectTimeout=5 "$remote" 'true' 2>/dev/null; then
        echo "ok"
    else
        echo "FAILED"
        echo "  (check network, SSH key, hostname/port; try: ssh ${SSH_BASE_OPTS[*]:-} ${remote})"
        exit 1
    fi

    printf 'repos dir:  ~/%s ... ' "$NAS_REPOS_DIR"
    local result
    if result=$(ssh ${SSH_BASE_OPTS[@]+"${SSH_BASE_OPTS[@]}"} -o BatchMode=yes "$remote" "
        set -e
        if [ ! -d ~/'${NAS_REPOS_DIR}' ]; then
            echo MISSING
            exit 0
        fi
        cd ~/'${NAS_REPOS_DIR}'
        shopt -s nullglob
        n=0
        for d in *.git; do
            [ -d \"\$d\" ] && n=\$((n+1))
        done
        echo \"OK \$n\"
    " 2>/dev/null); then
        case "$result" in
            MISSING)
                echo "missing (will be created on first 'local-repo create')"
                ;;
            OK\ *)
                echo "ok (${result#OK } repos)"
                ;;
            *)
                echo "unexpected response: ${result}"
                ;;
        esac
    else
        echo "could not check"
    fi
}

config_usage() {
    cat <<EOF
Usage:
  local-repo config                   show current settings
  local-repo config set <key> <val>   set a value and save to ${CONFIG_FILE}
  local-repo config unset <key>       clear a value
  local-repo config path              print path to config file

Keys: user, host, port, repos-dir
EOF
}

cmd_config() {
    if [[ $# -eq 0 ]]; then
        echo "config file: ${CONFIG_FILE}"
        if [[ ! -f "$CONFIG_FILE" ]]; then
            echo "             (not present — run 'local-repo config set ...' to create)"
        fi
        echo
        echo "  user      = ${NAS_USER:-(unset)}"
        echo "  host      = ${NAS_HOST:-(unset)}"
        echo "  port      = ${NAS_PORT:-(default, 22)}"
        echo "  repos-dir = ${NAS_REPOS_DIR}"
        return 0
    fi

    local sub="$1"; shift

    case "$sub" in
        set)
            if [[ $# -ne 2 ]]; then
                config_usage >&2
                exit 2
            fi
            local key="$1" value="$2"
            validate_conf_value "$key" "$value"
            case "$key" in
                user)      NAS_USER="$value" ;;
                host)      NAS_HOST="$value" ;;
                port)
                    if [[ ! "$value" =~ ^[0-9]+$ ]]; then
                        echo "error: port must be a positive integer" >&2
                        exit 2
                    fi
                    NAS_PORT="$value"
                    ;;
                repos-dir)
                    validate_repos_dir "$value"
                    NAS_REPOS_DIR="$value"
                    ;;
                *)
                    echo "error: unknown key '$key' (expected: user, host, port, repos-dir)" >&2
                    exit 2
                    ;;
            esac
            write_config
            echo "set ${key} = ${value}"
            ;;
        unset)
            if [[ $# -ne 1 ]]; then
                config_usage >&2
                exit 2
            fi
            local key="$1"
            case "$key" in
                user)      NAS_USER="" ;;
                host)      NAS_HOST="" ;;
                port)      NAS_PORT="" ;;
                repos-dir) NAS_REPOS_DIR="repos" ;;
                *)
                    echo "error: unknown key '$key' (expected: user, host, port, repos-dir)" >&2
                    exit 2
                    ;;
            esac
            write_config
            echo "unset ${key}"
            ;;
        path)
            echo "$CONFIG_FILE"
            ;;
        -h|--help|help)
            config_usage
            ;;
        *)
            echo "error: unknown config subcommand '$sub'" >&2
            config_usage >&2
            exit 2
            ;;
    esac
}

main() {
    load_config

    if [[ $# -lt 1 ]]; then
        usage >&2
        exit 2
    fi

    local subcmd="$1"
    shift

    case "$subcmd" in
        init)           cmd_init "$@" ;;
        set-backup)     cmd_set_backup "$@" ;;
        create)         cmd_create "$@" ;;
        list|ls)        cmd_list "$@" ;;
        delete|rm)      cmd_delete "$@" ;;
        url)            cmd_url "$@" ;;
        status)         cmd_status "$@" ;;
        config)         cmd_config "$@" ;;
        -h|--help|help) usage ;;
        *)
            echo "error: unknown subcommand '$subcmd'" >&2
            usage >&2
            exit 2
            ;;
    esac
}

main "$@"
